---
/* Sección Hero principal con animaciones */
---

<main class="relative min-h-screen flex items-center justify-center px-4 pt-20">
	<div class="max-w-5xl mx-auto text-center">

		<!-- Badge superior -->
		<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-cyan/20 bg-cyan/5 backdrop-blur-sm mb-8 animate-fade-in">
			<span class="relative flex h-2 w-2">
				<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan opacity-75"></span>
				<span class="relative inline-flex rounded-full h-2 w-2 bg-cyan"></span>
			</span>
			<span class="text-cyan text-sm font-medium tracking-wide">UNIVERSIDAD NACIONAL DE LUJÁN</span>
		</div>

		<!-- Título principal -->
		<h1 class="opacity-0 animate-slide-up">
			<span class="block font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black tracking-tight leading-none">
				<span class="text-white">E-SPORTS</span>
			</span>
			<span class="block font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black tracking-tight leading-none mt-2">
				<span class="bg-gradient-to-r from-cyan via-cyan to-green-unlu bg-clip-text text-transparent">UNLu</span>
			</span>
		</h1>

		<!-- Línea decorativa -->
		<div class="flex items-center justify-center gap-4 my-8 opacity-0 animate-slide-up-delay">
			<div class="h-px w-16 sm:w-24 bg-gradient-to-r from-transparent to-cyan/50"></div>
			<div class="w-3 h-3 rotate-45 border border-orange bg-orange/20"></div>
			<div class="h-px w-16 sm:w-24 bg-gradient-to-l from-transparent to-cyan/50"></div>
		</div>

		<!-- Subtítulo / Próximamente -->
		<div class="opacity-0 animate-slide-up-delay-2">
			<p class="text-lg sm:text-xl md:text-2xl text-white/60 font-light mb-6 max-w-2xl mx-auto">
				La comunidad gamer de la UNLu está por llegar
			</p>

			<!-- Card de inscripciones -->
			<div class="relative inline-block group">
				<div class="absolute -inset-1 bg-gradient-to-r from-cyan via-orange to-cyan rounded-2xl blur-lg opacity-30 group-hover:opacity-60 transition-opacity duration-500"></div>
				<div class="relative px-8 py-6 sm:px-12 sm:py-8 rounded-2xl bg-dark-lighter/80 backdrop-blur-xl border border-cyan/20 animate-glow-border">
					<p class="text-cyan/80 text-sm font-medium tracking-[0.3em] uppercase mb-2">🎮 Prepárate</p>
					<h2 class="font-display text-2xl sm:text-3xl md:text-4xl font-bold text-white tracking-wide">
						INSCRIPCIONES
					</h2>
					<h2 class="font-display text-2xl sm:text-3xl md:text-4xl font-bold tracking-wide mt-1">
						<span class="bg-gradient-to-r from-orange via-orange to-yellow-400 bg-clip-text text-transparent">PRÓXIMAMENTE</span>
					</h2>
					<div class="mt-4 flex items-center justify-center gap-2 text-white/40 text-sm">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
						</svg>
						<span>Próximamente abrimos inscripciones</span>
					</div>
				</div>
			</div>
		</div>

		<!-- Features / Tags -->
		<div class="mt-16 flex flex-wrap items-center justify-center gap-3 opacity-0 animate-slide-up-delay-2" style="animation-delay: 0.6s;">
			<span class="feature-tag">
				<svg class="w-4 h-4 text-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
				Torneos
			</span>
			<span class="feature-tag">
				<svg class="w-4 h-4 text-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
				Comunidad
			</span>
			<span class="feature-tag">
				<svg class="w-4 h-4 text-green-unlu" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
				Competitivo
			</span>
			<span class="feature-tag">
				<svg class="w-4 h-4 text-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
				Streaming
			</span>
		</div>

		<!-- Scroll indicator -->
		<div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/30 animate-float">
			<span class="text-xs tracking-widest uppercase">Scroll</span>
			<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
			</svg>
		</div>
	</div>
</main>

<style>
	.feature-tag {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		border-radius: 9999px;
		border: 1px solid rgba(100, 255, 218, 0.1);
		background: rgba(30, 41, 59, 0.5);
		backdrop-filter: blur(8px);
		font-size: 0.875rem;
		color: rgba(255, 255, 255, 0.7);
		transition: all 0.3s ease;
	}
	.feature-tag:hover {
		border-color: rgba(100, 255, 218, 0.3);
		background: rgba(100, 255, 218, 0.05);
		color: #fff;
		transform: translateY(-2px);
	}
</style>
